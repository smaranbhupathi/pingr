# Copy this to .env and fill in real values.
# .env is gitignored — never commit secrets.

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Secret used to sign JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=

# Your app's public URL (used in email links)
APP_BASE_URL=https://pingr.yourdomain.com

APP_ENV=production
PORT=8080
WORKER_REGION=sin  # Must match the region set in monitor.go defaultRegion

# Resend API key for transactional email — get from resend.com
RESEND_API_KEY=

# The "from" address for outbound emails (must be a verified Resend domain)
FROM_EMAIL=noreply@yourdomain.com

# Frontend origin for CORS — use * in dev, exact URL in prod
# Example: https://pingr.yourdomain.com
ALLOWED_ORIGIN=*

# ── Object storage (optional — leave unset to disable avatar uploads) ─────────
# Supports Cloudflare R2, AWS S3, or MinIO (local dev).
# To use MinIO locally: docker run -p 9000:9000 minio/minio server /data
#
# Cloudflare R2:
#   STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_REGION=auto
#   STORAGE_ACCESS_KEY_ID=<R2 API token ID>
#   STORAGE_SECRET_ACCESS_KEY=<R2 API token secret>
#   STORAGE_BUCKET=pingr-avatars
#   STORAGE_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev   # or your custom domain
#
# MinIO (local):
#   STORAGE_ENDPOINT=http://localhost:9000
#   STORAGE_REGION=us-east-1
#   STORAGE_ACCESS_KEY_ID=minioadmin
#   STORAGE_SECRET_ACCESS_KEY=minioadmin
#   STORAGE_BUCKET=avatars
#   STORAGE_PUBLIC_BASE_URL=http://localhost:9000/avatars
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=
STORAGE_PUBLIC_BASE_URL=
