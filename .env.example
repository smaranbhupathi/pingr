# Copy this to .env and fill in real values.
# .env is gitignored — never commit secrets.

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Secret used to sign JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=

# Your app's public URL (used in email links)
APP_BASE_URL=https://pingr.yourdomain.com

APP_ENV=production
PORT=8080
WORKER_REGION=sin

# Resend API key for transactional email — get from resend.com
RESEND_API_KEY=

# The "from" address for outbound emails (must be a verified Resend domain)
FROM_EMAIL=noreply@yourdomain.com

# Frontend origin for CORS — use * in dev, exact URL in prod
# Example: https://pingr.yourdomain.com
ALLOWED_ORIGIN=*
